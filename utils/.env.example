# ============================================================
# Smart AI Resume Analyzer - Environment Variables Template
# ============================================================
# Copy this file to utils/.env and fill in your actual values.
# NEVER commit utils/.env to version control.
# ============================================================

# ── AI Model API Keys ──────────────────────────────────────
# Google Gemini API Key (required for AI resume analysis)
# Get yours at: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_google_gemini_api_key_here

# OpenRouter API Key (optional — alternative LLM provider)
# Get yours at: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# ── Database Configuration (optional) ──────────────────────
# Custom SQLite database path (default: resume_data.db in project root)
# DB_PATH=custom_database_path.db

# ── App Configuration (optional) ───────────────────────────
# DEBUG=True
# LOG_LEVEL=INFO
